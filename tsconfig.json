{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": [
      "ES2020"
    ],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@parser": [
        "src/parser"
      ],
      "@security": [
        "src/security"
      ],
      "@tools": [
        "src/tools"
      ],
      "@resolver": [
        "src/resolver"
      ],
      "@rag": [
        "src/rag"
      ],
      "@pi-agent": [
        "src/pi-agent"
      ],
      "@parser/*": [
        "src/parser/*"
      ],
      "@security/*": [
        "src/security/*"
      ],
      "@tools/*": [
        "src/tools/*"
      ],
      "@resolver/*": [
        "src/resolver/*"
      ],
      "@rag/*": [
        "src/rag/*"
      ],
      "@pi-agent/*": [
        "src/pi-agent/*"
      ]
    },
    "types": [
      "node"
    ]
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "examples"
  ]
}